ENV=dev

# --- Postgres ---
DATABASE_URL=postgresql+asyncpg://USER:PASS@HOST:5432/pitchiq
SYNC_DATABASE_URL=postgresql+psycopg://USER:PASS@HOST:5432/pitchiq
CHECKPOINTER_DB_URL=postgresql://USER:PASS@HOST:5432/pitchiq?options=-c%20search_path%3Dlanggraph

# --- OpenAI ---
OPENAI_API_KEY=sk-...
MODEL_ROUTER=gpt-4o-mini
MODEL_AGENT=gpt-4o-mini
MODEL_CRITIC=gpt-4o

# --- Sports / odds providers ---
API_FOOTBALL_KEY=
FOOTBALL_DATA_TOKEN=
THE_ODDS_API_KEY=

# --- Auth ---
JWT_SECRET=change-me-32-bytes-base64
JWT_ALG=HS256
ACCESS_TOKEN_TTL_MIN=1440
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback

# --- LangSmith ---
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pitch-iq

# --- Runtime config ---
RUN_SCHEDULER=true
CORS_ORIGINS=http://localhost:3000
LIVE_POLL_SECONDS=60
BRIEFING_LEAD_HOURS=2
TOURNAMENT_SLUG=world-cup-2026
